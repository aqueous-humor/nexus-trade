# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the Laravel API. In development this is typically localhost:8000.
# In production set to your deployed API domain, e.g. https://api.nexustrade.io
VITE_API_URL=http://localhost:8000

# ── WebSocket / Real-time (Soketi in dev, Pusher or Soketi in prod) ───────────
# Leave VITE_PUSHER_APP_KEY blank to disable WebSocket and fall back to polling.
VITE_PUSHER_APP_KEY=nexustrade-key
VITE_PUSHER_HOST=localhost
VITE_PUSHER_PORT=6001
# Set to "https" in production when Soketi/Pusher is behind TLS
VITE_PUSHER_SCHEME=http
