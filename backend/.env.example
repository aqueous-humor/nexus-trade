# ============================================================
# NexusTrade — Environment Variables Reference
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME=NexusTrade
APP_ENV=local                        # local | testing | production
APP_KEY=                             # Run: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173   # Used for CORS and email links

# ------------------------------------------------------------
# Database — MySQL 8 / MariaDB 10.6+
# ------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexustrade
DB_USERNAME=nexustrade
DB_PASSWORD=secret

# ------------------------------------------------------------
# Cache, Queue, Session — Redis 7
# Swap CACHE_DRIVER / QUEUE_CONNECTION to 'array' for testing
# ------------------------------------------------------------
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_CLIENT=predis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------
# Email
# MAIL_MAILER options: smtp | mailgun | ses | postmark | log | array
# For local dev use mailpit (MAIL_HOST=localhost, MAIL_PORT=1025)
# ------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@nexustrade.local"
MAIL_FROM_NAME="${APP_NAME}"

# Optional: Mailgun driver
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net

# Optional: AWS SES driver
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_SES_REGION=us-east-1

# Optional: Postmark driver
POSTMARK_TOKEN=

# ------------------------------------------------------------
# Broadcasting & WebSocket — Pusher protocol (Soketi / Pusher / Ably)
# Point PUSHER_HOST at your Soketi instance or pusher.com
# For local dev: PUSHER_HOST=localhost, PUSHER_PORT=6001, PUSHER_SCHEME=http
# ------------------------------------------------------------
BROADCAST_DRIVER=pusher

PUSHER_APP_ID=nexustrade
PUSHER_APP_KEY=nexustrade-key
PUSHER_APP_SECRET=nexustrade-secret
PUSHER_HOST=localhost
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# ------------------------------------------------------------
# Laravel Horizon
# ------------------------------------------------------------
HORIZON_PREFIX=nexustrade_horizon:

# ------------------------------------------------------------
# Sanctum — SPA domains (comma-separated)
# ------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1

# ------------------------------------------------------------
# Fraud Detection
# ------------------------------------------------------------
FRAUD_HIGH_FREQUENCY_THRESHOLD=3        # deposits in window
FRAUD_HIGH_FREQUENCY_WINDOW_MINUTES=10
FRAUD_LARGE_TRANSACTION_USD=10000
FRAUD_UNUSUAL_WITHDRAWAL_RATIO=0.80     # 80% of 30-day deposits
FRAUD_AUTO_REVIEW_SCORE=80              # score threshold for pending_review

# ------------------------------------------------------------
# Withdrawal Limits (USD)
# ------------------------------------------------------------
WITHDRAWAL_DAILY_LIMIT_USD=5000
WITHDRAWAL_MONTHLY_LIMIT_USD=50000

# ------------------------------------------------------------
# Demo Account Default Balance (USD cents)
# ------------------------------------------------------------
DEMO_ACCOUNT_DEFAULT_BALANCE_CENTS=1000000   # $10,000

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
